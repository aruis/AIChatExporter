{
  "manifest_version": 3,
  "default_locale": "en",
  "name": "__MSG_extension_name__",
  "description": "__MSG_extension_description__",
  "version": "1.0",
  "icons": {
    "48": "images/icon-48.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png",
    "256": "images/icon-256.png",
    "512": "images/icon-512.png"
  },
  "background": {
    "scripts": [
      "background.js"
    ],
    "type": "module"
  },
  "content_scripts": [
    {
      "js": [
        "ai_providers.js",
        "kimi.js",
        "chatgpt.js",
        "claude.js",
        "gemini.js",
        "perplexity.js",
        "content_runtime.js",
        "content_markdown_serializer.js",
        "content_extractors.js",
        "content.js"
      ],
      "matches": [
        "*://*/*"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "images/icon.svg"
  },
  "permissions": [
    "activeTab",
    "nativeMessaging",
    "tabs",
    "storage"
  ]
}
